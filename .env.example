# Copier ce fichier en .env.local et remplir avec vos clés Supabase
# Supabase → Project Settings → API
#
# Pour éviter la mise en pause du projet gratuit (inactivité 7 jours),
# ajoutez aussi ces 2 secrets sur GitHub :
# Settings → Secrets and variables → Actions → New repository secret
#   SUPABASE_URL
#   SUPABASE_ANON_KEY

VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici
